---
const { linkTitle, linkDescription, linkUrl } = Astro.props
---

<div class='flex flex-col items-center w-full gap-y-8 mt-xl gap-[var(--link-gap)] '>
  <div
    class='flex flex-row justify-center items-center justify-center rounded-lg bg-gradient-to-br from-[#f0f0f0] to-[#d9d9d9] shadow-lg transition-all duration-500 hover:scale-105 hover:shadow-xl'
    style='--link-gap: 1rem;'
  >
    <a href={linkUrl}
      ><button
        ><span class='font-semibold'>{linkTitle}{" "}</span>{
          linkDescription
        }</button
      >
    </a>
  </div>
</div>
