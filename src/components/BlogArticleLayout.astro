---
import type { CollectionEntry } from "astro:content";
import { formatDate, languages, t, type SupportedLanguage } from "../i18n";
import type { Tab } from "../utils/blog";
import ArticleTabs from "./ArticleTabs.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";

interface Props {
  /** Main post used for metadata (title, date, author, category) */
  mainPost: CollectionEntry<"blog">;
  lang: SupportedLanguage;
  tabs?: Tab[];
  baseSlug?: string;
  canonicalUrl: string;
  canonicalSlug: string;
  availableLanguages: SupportedLanguage[];
  /** Show featured image (only for simple, non-multi-section posts) */
  showFeaturedImage?: boolean;
}

const {
  mainPost,
  lang,
  tabs = [],
  baseSlug,
  canonicalUrl,
  canonicalSlug,
  availableLanguages,
  showFeaturedImage = false,
} = Astro.props;

const langPrefix = languages[lang].prefix;
const blogUrl = `${langPrefix}/blog`;
const siteBase = Astro.site || new URL("https://speedcubingcolombia.org");
const formattedDate = mainPost.data.date
  ? formatDate(mainPost.data.date, lang)
  : "";

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: mainPost.data.title,
  ...(mainPost.data.image && {
    image: new URL(mainPost.data.image, siteBase).toString(),
  }),
  ...(mainPost.data.date && {
    datePublished: mainPost.data.date.toISOString(),
  }),
  ...(mainPost.data.author && {
    author: { "@type": "Person", name: mainPost.data.author },
  }),
  publisher: {
    "@type": "Organization",
    name: "Speedcubing Colombia",
    url: siteBase.toString().replace(/\/$/, ""),
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  ...(mainPost.data.excerpt && { description: mainPost.data.excerpt }),
  inLanguage: lang,
});
---

<article class="pt-24 pb-16 md:pt-28 md:pb-24">
  <div class="container-custom max-w-4xl">
    <div class="mb-8 flex justify-between items-center">
      <a
        href={blogUrl}
        class="inline-flex items-center text-gray-600 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 mr-2"
          viewBox="0 0 20 20"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z"
            clip-rule="evenodd"></path>
        </svg>
        {t(lang, "blog.backToBlog")}
      </a>
      <LanguageSwitcher
        currentLang={lang}
        currentSlug={canonicalSlug}
        availableLanguages={availableLanguages}
      />
    </div>

    {
      (mainPost.data.category || formattedDate) && (
        <div class="flex items-center mb-6">
          {mainPost.data.category && (
            <span class="inline-block px-3 py-1 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-300 font-medium text-sm">
              {mainPost.data.category}
            </span>
          )}
          {mainPost.data.category && formattedDate && (
            <span class="mx-2 text-gray-300 dark:text-gray-600">&bull;</span>
          )}
          {formattedDate && (
            <span class="text-gray-600 dark:text-gray-400">
              {formattedDate}
            </span>
          )}
        </div>
      )
    }

    <h1
      class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 text-gray-900 dark:text-white"
    >
      {mainPost.data.title}
    </h1>

    {
      mainPost.data.author && (
        <div class={`flex items-center ${tabs.length > 1 ? "mb-0" : "mb-8"}`}>
          {mainPost.data.authorAvatar && (
            <img
              src={mainPost.data.authorAvatar}
              alt={mainPost.data.author}
              class="w-12 h-12 mr-4 object-contain"
            />
          )}
          <div>
            <p class="font-semibold text-gray-900 dark:text-white">
              {mainPost.data.author}
            </p>
            {mainPost.data.authorRole && (
              <p class="text-gray-600 dark:text-gray-400">
                {mainPost.data.authorRole}
              </p>
            )}
          </div>
        </div>
      )
    }

    {
      showFeaturedImage && mainPost.data.image && (
        <img
          src={mainPost.data.image}
          alt={mainPost.data.title}
          class="w-full h-auto rounded-xl mb-10 object-cover"
          style="max-height: 500px;"
        />
      )
    }
  </div>

  {
    tabs.length > 1 && baseSlug && (
      <ArticleTabs tabs={tabs} baseSlug={baseSlug} langPrefix={langPrefix} />
    )
  }

  <div class="container-custom max-w-4xl">
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <slot />
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
      <h3 class="text-xl font-semibold mb-6 text-gray-900 dark:text-white">
        {t(lang, "blog.shareArticle")}
      </h3>
      <div class="flex flex-wrap gap-4">
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(mainPost.data.title)}&url=${encodeURIComponent(canonicalUrl)}`}
          class="p-2 bg-gray-100 dark:bg-gray-800 rounded-full text-gray-600 dark:text-gray-300 hover:bg-primary-100 hover:text-primary-600 dark:hover:bg-primary-900/50 dark:hover:text-primary-400 transition-colors"
          aria-label={t(lang, "blog.shareTwitter")}
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"
            ></path>
          </svg>
        </a>
        <a
          href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(canonicalUrl)}&title=${encodeURIComponent(mainPost.data.title)}`}
          class="p-2 bg-gray-100 dark:bg-gray-800 rounded-full text-gray-600 dark:text-gray-300 hover:bg-primary-100 hover:text-primary-600 dark:hover:bg-primary-900/50 dark:hover:text-primary-400 transition-colors"
          aria-label={t(lang, "blog.shareLinkedin")}
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
        <a
          href={`https://www.facebook.com/sharer.php?u=${encodeURIComponent(canonicalUrl)}`}
          class="p-2 bg-gray-100 dark:bg-gray-800 rounded-full text-gray-600 dark:text-gray-300 hover:bg-primary-100 hover:text-primary-600 dark:hover:bg-primary-900/50 dark:hover:text-primary-400 transition-colors"
          aria-label={t(lang, "blog.shareFacebook")}
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
  <script type="application/ld+json" set:html={jsonLd} />
</article>
