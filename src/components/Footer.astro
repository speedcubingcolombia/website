---
import { FOOTER_LINKS, SITE_CONFIG } from "../config/site";
import { getLocaleFromPath, t } from "../i18n";
import SocialLinks from "./SocialLinks.astro";

const currentPath = new URL(Astro.request.url).pathname;
const lang = getLocaleFromPath(currentPath);
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white pt-16 pb-8" role="contentinfo">
  <div class="container-custom">
    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-8 mb-12">
      <div class="md:col-span-2 lg:col-span-2">
        <a
          href="/"
          class="flex items-center mb-6"
          aria-label={t(lang, "a11y.goHome")}
        >
          <img
            class="h-8 w-auto text-primary-400"
            src="/favicon.svg"
            alt="Logo de Speedcubing Colombia"
          />
          <span class="ml-2 text-xl font-display font-semibold text-white">
            {SITE_CONFIG.name}
          </span>
        </a>
        <p class="text-gray-400 mb-6 max-w-md">
          {t(lang, "footer.description")}
        </p>
        <SocialLinks variant="light" />
      </div>

      {
        FOOTER_LINKS.map((column) => (
          <div>
            <h3 class="text-lg font-semibold mb-4">
              {t(lang, column.titleKey)}
            </h3>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.url}
                    class="text-gray-400 hover:text-primary-400 transition-colors"
                    {...("external" in link && link.external
                      ? {
                          target: "_blank",
                          rel: "noopener noreferrer",
                        }
                      : {})}
                  >
                    {t(lang, link.key)}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="border-t border-gray-800 pt-8 mt-8">
      <div class="flex flex-col md:flex-row justify-between items-center">
        <p class="text-gray-400 text-sm mb-4 md:mb-0">
          &copy; {currentYear}
          {SITE_CONFIG.name}. {t(lang, "footer.allRightsReserved")}.
        </p>
        <div class="flex space-x-6">
          <a
            href="/privacy-policy"
            class="text-gray-400 hover:text-primary-400 text-sm transition-colors"
          >
            {t(lang, "footer.privacyPolicy")}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
