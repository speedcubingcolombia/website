---
import BlogArticleLayout from "../../../components/BlogArticleLayout.astro";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import Layout from "../../../layouts/Layout.astro";
import { addLangPrefix } from "../../../i18n";
import {
  buildAlternateUrls,
  generateTabs,
  getAvailableLanguages,
  getCanonicalSlug,
  getSlugPaths,
  type SlugPathProps,
} from "../../../utils/blog";

const lang = "pt" as const;

export async function getStaticPaths() {
  return getSlugPaths("pt");
}

type Props = SlugPathProps;

const { post, multiSection, allSections, baseSlug } = Astro.props;
const { Content } = await post.render();

const canonicalSlug = getCanonicalSlug(baseSlug, lang);
const availableLanguages = await getAvailableLanguages(canonicalSlug);
const tabs =
  multiSection && allSections.length > 0
    ? generateTabs(allSections, "index", post, lang)
    : [];

const blogPath = addLangPrefix(`/blog/${baseSlug}`, lang);
const canonicalUrl = Astro.site
  ? new URL(blogPath, Astro.site).toString()
  : blogPath;
const alternateUrls = buildAlternateUrls(canonicalSlug, availableLanguages, Astro.site);
---

<Layout
  title={`${post.data.title} | Speedcubing Colombia`}
  description={post.data.excerpt}
  image={post.data.image}
  type="article"
  lang={lang}
  alternateUrls={alternateUrls}
>
  <Header />
  <main id="main-content">
    <BlogArticleLayout
      mainPost={post}
      lang={lang}
      tabs={tabs}
      baseSlug={baseSlug}
      canonicalUrl={canonicalUrl}
      canonicalSlug={canonicalSlug}
      availableLanguages={availableLanguages}
      showFeaturedImage={!multiSection}
    >
      <Content />
    </BlogArticleLayout>
  </main>
  <Footer />
</Layout>
